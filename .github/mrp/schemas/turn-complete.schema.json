{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/momhq/mom/mrp/v0/turn-complete",
  "title": "MRP v0 — turn.complete event",
  "description": "Emitted when one full turn finishes (user prompt + harness response). Opt-in — adapters that cannot track turn boundaries must not synthesize this event.",
  "type": "object",
  "required": ["mrp_version", "event", "session_id", "harness", "timestamp", "turn_index"],
  "additionalProperties": false,
  "properties": {
    "mrp_version": {
      "type": "string",
      "const": "v0",
      "description": "MRP protocol version"
    },
    "event": {
      "type": "string",
      "const": "turn.complete",
      "description": "Event type discriminator"
    },
    "session_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique session identifier"
    },
    "harness": {
      "type": "string",
      "minLength": 1,
      "description": "Adapter name"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the event was emitted (RFC3339)"
    },
    "turn_index": {
      "type": "integer",
      "minimum": 0,
      "description": "Zero-based index of this turn within the session"
    },
    "prompt_tokens": {
      "type": "integer",
      "minimum": 0,
      "description": "Token count for the user prompt (optional)"
    },
    "completion_tokens": {
      "type": "integer",
      "minimum": 0,
      "description": "Token count for the harness response (optional)"
    }
  }
}
